{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "node ./scripts/dev-server.mjs",
    "build": "next build --webpack",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "tsx --test src/server/auth/users.test.ts src/server/domain/catalog.test.ts src/server/domain/orders.test.ts",
    "test:integration": "tsx --test tests/integration/api-flows.test.ts",
    "test:e2e": "playwright test",
    "test:release": "npm run test && npm run build && npm run test:e2e",
    "cms:import": "node ./scripts/import-cms-content.mjs",
    "cms:import:inbox": "node ./scripts/import-cms-content.mjs",
    "cms:import:inbox:dry": "node ./scripts/import-cms-content.mjs --dry-run",
    "cms:fix-array-keys": "node ./scripts/fix-sanity-array-keys.mjs",
    "cms:fix-array-keys:dry": "node ./scripts/fix-sanity-array-keys.mjs --dry-run"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@playwright/test": "^1.55.0",
    "@sanity/client": "^7.21.0",
    "@supabase/supabase-js": "^2.104.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.37.0",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.0",
    "motion-dom": "^12.37.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "vitest": "^4.1.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
